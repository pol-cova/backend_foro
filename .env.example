# Server port (default 3000 for prod; use 3145 for local dev to avoid conflicts)
# Note: In Docker, the container always listens on 3000. Map host port via PORT env in compose.
PORT="3145"

# debug | info | warn | error (default info). debug enables logger.debug; access HTTP lines always log.
# LOG_LEVEL="info"

# for load testing
# TESTING="true"

# per-IP rate limit for registration (default 100/min)
# RATE_LIMIT_MAX="100"

DATABASE_URL="mongodb://root:foro@localhost:27017/foro"
JWT_SECRET="supersecret"
EXTERNAL_API_URL="http://148.202.89.11/d_alum/api/siiau-login"

CORS_ORIGIN="http://localhost:5173"

# SISPA (perfil API for prefill) 
SISPA_URL="https://sispacuvalles.udg.mx"
